{
  "name": "play2go-wiki",
  "type": "module",
  "devDependencies": {
    "@unocss/preset-attributify": "66.6.7",
    "@unocss/transformer-directives": "66.6.7",
    "@unocss/transformer-variant-group": "66.6.7",
    "sass": "1.98.0",
    "unocss": "66.6.7",
    "vitepress": "1.6.4",
    "vitepress-plugin-tabs": "0.8.0",
    "vitepress-sidebar": "1.33.1",
    "vue": "3.5.30",
    "markdownlint-cli": "0.48.0"
  },
  "scripts": {
    "dev": "vitepress dev",
    "devhost": "vitepress dev --host",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "check": "markdownlint *.md && markdownlint src/",
    "attemptfix": "markdownlint --fix *.md && markdownlint --fix src/ && git status",
    "fixandcommit": "markdownlint --fix *.md && markdownlint --fix src/ && git commit -am 'Автоматическая обработка линтером (команда bun run fixandcommit)'"
  },
  "dependencies": {
    "@vueuse/core": "14.2.1"
  }
}
